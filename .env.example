# OpenAI API key for local testing (optional)
OPENAI_API_KEY=replace-with-openai-api-key

# Anthropic API key for local testing (optional)
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# Chrome Web Store API credentials for extension publishing (optional)
CHROME_WEBSTORE_CLIENT_ID=replace-with-client-id
CHROME_WEBSTORE_CLIENT_SECRET=replace-with-client-secret
CHROME_WEBSTORE_REFRESH_TOKEN=replace-with-refresh-token
CHROME_WEBSTORE_EXTENSION_ID=replace-with-extension-id