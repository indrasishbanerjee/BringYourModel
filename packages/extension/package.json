{
  "name": "@byom/extension",
  "version": "1.0.0",
  "private": true,
  "description": "Bring Your Model - Chrome Extension (OpenModelRouter engine)",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "lint": "eslint entrypoints modules",
    "typecheck": "pnpm --filter @byom/shared build && wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/cohere": "^2.0.29",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/groq": "^2.0.40",
    "@ai-sdk/mistral": "^2.0.33",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@byom/shared": "file:../shared",
    "ai": "^6.0.0",
    "dexie": "^4.0.0",
    "lucide-react": "^0.462.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@wxt-dev/auto-icons": "^1.0.0",
    "@wxt-dev/module-react": "^1.1.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wxt": "^0.19.0"
  }
}
