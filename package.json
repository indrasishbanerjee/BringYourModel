{
  "name": "bringyourmodel",
  "version": "0.0.0",
  "private": true,
  "description": "Bring Your Model - User-owned AI access layer for the browser",
  "repository": {
    "type": "git",
    "url": "https://github.com/indrasishbanerjee/BringYourModel"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter extension dev",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @byom/shared --filter @byom/extension --filter @byomsdk/sdk test",
    "test:e2e": "pnpm --filter @byom/e2e test",
    "check:bundle": "node scripts/check-bundle.mjs",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "publish:sdk": "pnpm --filter @byomsdk/sdk publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4"
  }
}
